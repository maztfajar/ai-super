# ============================================================
# AI ORCHESTRATOR — Environment Configuration
# Copy this to .env and fill in your values
# JANGAN commit file .env ke Git!
# ============================================================

# ── App Settings ──────────────────────────────────────────────
APP_NAME="AI ORCHESTRATOR"
APP_VERSION="2.5.0"

# WAJIB diganti! Generate dengan: python3 -c "import secrets; print(secrets.token_hex(32))"
# Atau biarkan install.sh generate otomatis saat instalasi.
SECRET_KEY="GANTI-INI-DENGAN-RANDOM-STRING-MINIMAL-32-KARAKTER"

DEBUG=false
HOST=0.0.0.0
PORT=7860
UVICORN_WORKERS=2

# ── Database ──────────────────────────────────────────────────
# Pilih salah satu. SQLite lebih mudah untuk development/personal.

# SQLite (default — tidak perlu instalasi tambahan):
DATABASE_URL=sqlite+aiosqlite:///./data/ai-orchestrator.db

# PostgreSQL (disarankan untuk production/server):
# DATABASE_URL=postgresql+asyncpg://ai_orchestrator_user:PASSWORD@localhost/ai_orchestrator_db

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── AI API Keys ───────────────────────────────────────────────
# Isi minimal satu untuk mulai. Gratis: gunakan Ollama lokal.

OPENAI_API_KEY=sk-...
OPENAI_AVAILABLE_MODELS=gpt-4o,gpt-4o-mini

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_AVAILABLE_MODELS=claude-sonnet-4-20250514,claude-haiku-4-5-20251001

GOOGLE_API_KEY=AIza...
GOOGLE_AVAILABLE_MODELS=gemini-2.5-flash,gemini-2.0-flash

# ── Ollama (Local AI — Gratis!) ───────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1
OLLAMA_AVAILABLE_MODELS=llama3.1,mistral

# ── Default Model ─────────────────────────────────────────────
# Ganti sesuai API key yang kamu miliki.
# Gratis (lokal): ollama/llama3.1
# Berbayar: claude-sonnet-4-20250514 / gpt-4o / gemini-2.5-flash
DEFAULT_MODEL=claude-sonnet-4-20250514

# ── Sumopod ───────────────────────────────────────────────────
SUMOPOD_HOST=https://ai.sumopod.com/v1
SUMOPOD_API_KEY=
SUMOPOD_AVAILABLE_MODELS=

# ── Google Drive ──────────────────────────────────────────────
GDRIVE_UPLOAD_FOLDER_ID=

# ── RAG / Vector DB ───────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Atau gunakan OpenAI embeddings (berbayar):
# EMBEDDING_MODEL=text-embedding-3-small

# ── Telegram Bot ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=https://yourserver.com/api/integrations/telegram/webhook

# ── WhatsApp ──────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=ai-orchestrator-verify

# ── Admin Account ─────────────────────────────────────────────
# WAJIB diganti setelah instalasi!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=GANTI-INI-DENGAN-PASSWORD-KUAT
ADMIN_EMAIL=admin@yourdomain.com

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ── File Upload ───────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,txt,csv,md,json

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./data/logs/ai-orchestrator.log

# ── Cloudflare Tunnel ─────────────────────────────────────────
TUNNEL_ENABLED=false
TUNNEL_PROVIDER=cloudflare
TUNNEL_DOMAIN=
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_ID=
TUNNEL_AUTO_START=false

# ── Email (SMTP) — untuk reset password via email ─────────────
# Gmail   : smtp.gmail.com  port 587 (gunakan App Password)
# Outlook : smtp.office365.com port 587
# Mailtrap: smtp.mailtrap.io  port 2525 (untuk testing)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TLS=true

APP_URL=http://localhost:7860
