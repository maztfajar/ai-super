# ============================================================
#  PITAKONKU — Environment Configuration
#  Copy this to .env and fill in your API keys
# ============================================================

# ── App Settings ──────────────────────────────────────────────
APP_NAME="PITAKONKU"
APP_VERSION="1.0.0"
SECRET_KEY="pitakonku-secret-key-ganti-ini-dengan-random-string-panjang"
DEBUG=false
HOST=0.0.0.0
PORT=7860

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://pitakonku:pitakonku2024@localhost/pitakonku_db
# Uncomment for SQLite (simpler, no PostgreSQL needed):
# DATABASE_URL=sqlite+aiosqlite:///./data/pitakonku.db

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── AI API Keys ───────────────────────────────────────────────
# Isi minimal satu untuk mulai. Gratis: gunakan Ollama lokal.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# ── Ollama (Local AI — Gratis!) ───────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1

# ── Default Model ─────────────────────────────────────────────
DEFAULT_MODEL=claude-3-5-sonnet-20241022
# Jika tidak punya API key berbayar, gunakan: ollama/llama3.1

# ── RAG / Vector DB ───────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Atau gunakan OpenAI embeddings (berbayar):
# EMBEDDING_MODEL=text-embedding-3-small

# ── Telegram Bot ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=https://yourserver.com/api/integrations/telegram/webhook

# ── WhatsApp ──────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=pitakonku-verify

# ── Admin Account ─────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=pitakonku2024
ADMIN_EMAIL=admin@pitakonku.local

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ── File Upload ───────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,txt,csv,md,json

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./data/logs/pitakonku.log

# ── Cloudflare Tunnel ─────────────────────────────────────────
TUNNEL_ENABLED=false
TUNNEL_PROVIDER=cloudflare
TUNNEL_DOMAIN=
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_ID=
TUNNEL_AUTO_START=false

# ── Email (SMTP) — untuk reset password via email ─────────────
# Gmail: smtp.gmail.com port 587 (pakai App Password, bukan password Gmail)
# Outlook: smtp.office365.com port 587
# Mailtrap (testing): smtp.mailtrap.io port 2525
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TLS=true
APP_URL=http://localhost:7860
