# ============================================================
# AI ORCHESTRATOR — .gitignore
# ============================================================

# ── Kredensial & Konfigurasi Sensitif ────────────────────────
.env
.env.local
.env.production
.env.*.local

# ── Python ───────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.egg-info/
*.egg
.eggs/
dist/
build/
wheels/

# Virtual environment
venv/
**/venv/
.venv/
**/.venv/
scripts/venv/
env/
ENV/

# ── Node.js / Frontend ───────────────────────────────────────
node_modules/
**/node_modules/

# Vite build cache (jangan di-commit!)
.vite/
**/.vite/
frontend/.vite/

# Build output
dist/
build/
.next/
out/
frontend/dist/
frontend/build/

# ── Log Files ────────────────────────────────────────────────
*.log
*.log.*
logs/
**/logs/
data/logs/
cloudflared*.log
nohup.out

# ── Data & Upload ─────────────────────────────────────────────
data/
backend/data/
uploads/
**/uploads/

# Vector database (ChromaDB) — dibuat ulang saat runtime
data/chroma_db/
**/chroma_db/

# PID files
*.pid
data/*.pid

# ── Database ─────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Cache & Temp ─────────────────────────────────────────────
.cache/
**/.cache/
tmp/
temp/
*.tmp
*.swp
*.swo
*~

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
**/.DS_Store
Thumbs.db
desktop.ini

# ── IDE & Editor ─────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.iml
*.iws
*.ipr
.project
.classpath

# ── File Konfigurasi Runtime ─────────────────────────────────
# (di-generate otomatis, bukan bagian source code)
.webhooks.json
.custom_models.json
.domains.json

# ── Testing ───────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Docker ───────────────────────────────────────────────────
.docker/
.venv_test/
