# ══════════════════════════════════════════════════════════════
# AI SUPER ASSISTANT — Konfigurasi Lengkap
# Salin file ini ke .env dan isi nilainya
# cp .env.example .env
# ══════════════════════════════════════════════════════════════

# ── Keamanan (WAJIB diganti!) ─────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GANTI_DENGAN_STRING_ACAK_MINIMAL_32_KARAKTER

ADMIN_USERNAME=admin
ADMIN_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT_ANDA
ADMIN_EMAIL=admin@domain.com

# ── Aplikasi ──────────────────────────────────────────────────
APP_NAME=AI SUPER ASSISTANT
DEBUG=false
HOST=0.0.0.0
PORT=7860

# Izinkan registrasi publik? (false = hanya admin yang bisa buat akun)
ALLOW_PUBLIC_REGISTER=false

# ── Database ──────────────────────────────────────────────────
# SQLite (default, cocok untuk penggunaan single-user)
DATABASE_URL=sqlite+aiosqlite:///./data/ai-super-assistant.db

# PostgreSQL (rekomendasi untuk multi-user production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_super

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── AI Providers (isi minimal satu) ──────────────────────────
OPENAI_API_KEY=
# OPENAI_AVAILABLE_MODELS=gpt-4o,gpt-4o-mini

ANTHROPIC_API_KEY=
# ANTHROPIC_AVAILABLE_MODELS=claude-opus-4-6,claude-sonnet-4-6,claude-haiku-4-5-20251001

GOOGLE_API_KEY=
# GOOGLE_AVAILABLE_MODELS=gemini-2.5-pro,gemini-2.5-flash

# Sumopod (OpenAI-compatible provider)
SUMOPOD_API_KEY=
SUMOPOD_HOST=https://ai.sumopod.com/v1
# SUMOPOD_AVAILABLE_MODELS=model-id-1,model-id-2

# Ollama (model lokal)
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1
# OLLAMA_AVAILABLE_MODELS=llama3.1,mistral,codellama

# Model default jika tidak dipilih user
DEFAULT_MODEL=ollama/llama3.1

# ── Vision Model (untuk analisis gambar) ─────────────────────
# VISION_MODEL=gpt-4o
# VISION_MODEL=gemini-2.5-flash
# VISION_MODEL=sumopod/mimo-v2-omni

# ── RAG / Knowledge Base ──────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
RAG_DOCUMENTS_DIR=../rag_documents
RAG_TIMEOUT_SECONDS=45
EMBEDDING_PROVIDER=sumopod
# EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
SUMOPOD_EMBEDDING_MODEL=text-embedding-3-small

# ── Upload ────────────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,txt,csv,md,json,xlsx,xls,pptx,ppt

# ── Email / SMTP (untuk notifikasi & password reset) ─────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TLS=true
APP_URL=http://localhost:7860

# ── Telegram Bot ──────────────────────────────────────────────
# Untuk 2FA via Telegram & notifikasi
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# ── WhatsApp ──────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=ai-super-assistant-verify

# ── Google Drive ──────────────────────────────────────────────
GDRIVE_UPLOAD_FOLDER_ID=
GOOGLE_DRIVE_CREDENTIALS=

# ── Cloudflare Tunnel ─────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_API_TOKEN=

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./data/logs/ai-super-assistant.log
