# ============================================================
# AI ORCHESTRATOR — Default Configuration (baked into image)
# File ini otomatis digunakan jika .env tidak ada/tidak di-mount
# ============================================================

# ── App Settings ──────────────────────────────────────────────
APP_NAME="AI ORCHESTRATOR"
APP_VERSION="4.1.41"

# Auto-generated saat container pertama kali jalan
SECRET_KEY=__AUTO_GENERATED__

DEBUG=false
HOST=0.0.0.0
PORT=7860
UVICORN_WORKERS=2

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/ai-orchestrator.db

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── AI API Keys ───────────────────────────────────────────────
# Kosong secara default. Isi di Settings > API Keys setelah login.
OPENAI_API_KEY=
OPENAI_AVAILABLE_MODELS=gpt-4o,gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_AVAILABLE_MODELS=claude-sonnet-4-20250514,claude-haiku-4-5-20251001

GOOGLE_API_KEY=
GOOGLE_AVAILABLE_MODELS=gemini-2.5-flash,gemini-2.0-flash

# ── Ollama (Local AI — Gratis!) ───────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1
OLLAMA_AVAILABLE_MODELS=llama3.1,mistral

# ── Pollinations (Gratis — tanpa API key!) ────────────────────
POLLINATIONS_ENABLED=true
POLLINATIONS_MODEL=auto

# ── Voice Reply Settings ──────────────────────────────────────
VOICE_REPLY_ENABLED=true
VOICE_REPLY_LANGUAGE=id

# ── Default Model ─────────────────────────────────────────────
# Gratis (lokal): ollama/llama3.1 | Berbayar: gpt-4o / gemini-2.5-flash
DEFAULT_MODEL=pollinations/auto

# ── Sumopod ───────────────────────────────────────────────────
SUMOPOD_HOST=https://ai.sumopod.com/v1
SUMOPOD_API_KEY=
SUMOPOD_AVAILABLE_MODELS=

# ── Google Drive ──────────────────────────────────────────────
GDRIVE_UPLOAD_FOLDER_ID=

# ── RAG / Vector DB ───────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Telegram Bot ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=https://yourserver.com/api/integrations/telegram/webhook

# ── WhatsApp ──────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=ai-orchestrator-verify

# ── Admin Account (DEFAULT — ganti setelah login!) ────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@localhost

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ── File Upload ───────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,txt,csv,md,json

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./data/logs/ai-orchestrator.log

# ── Cloudflare Tunnel ─────────────────────────────────────────
TUNNEL_ENABLED=false
TUNNEL_PROVIDER=cloudflare
TUNNEL_DOMAIN=
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_ID=
TUNNEL_AUTO_START=false

# ── Email (SMTP) ──────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TLS=true

APP_URL=http://localhost:7860
TAVILY_API_KEY=
AI_ROLE_GENERAL=
AI_ROLE_CODING=
AI_ROLE_REASONING=
AI_ROLE_WRITING=
AI_ROLE_RESEARCH=
AI_ROLE_SYSTEM=
AI_ROLE_CREATIVE=
AI_ROLE_VALIDATION=
AI_ROLE_VISION=
AI_ROLE_MULTIMODAL=
AI_ROLE_AUDIO_GEN=
AI_ROLE_IMAGE_GEN=pollinations/auto
